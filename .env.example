# Backend
APP_ID=                   # Application ID
APP_SECRET=               # Application secret used for JWT signing

# Database (Supabase Postgres)
# Use Supabase Dashboard -> Project Settings -> Database -> Connection string ->
# Transaction pooler (URI). Keep this server-only; never expose it to Vite.
# Example:
# postgresql://postgres.<project-ref>:[YOUR-DB-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Supabase API (optional client/realtime usage)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=

# Frontend (exposed to browser via Vite)
VITE_KIMI_AUTH_URL=       # Kimi OAuth server URL
VITE_APP_ID=              # OAuth application ID
VITE_SOLANA_RPC_URL=      # Mainnet RPC URL; defaults to Solana mainnet-beta public endpoint if unset
VITE_SOCKET_URL=          # Optional Socket.io URL; defaults to current origin in production

# Optional embedded wallet provider placeholders
VITE_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Backend auth
KIMI_AUTH_URL=            # Kimi OAuth server URL
KIMI_OPEN_URL=            # Kimi Open Platform URL

# Admin role
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# $CHESS token
VITE_CHESS_MINT=          # Browser-visible $CHESS mint used for wager UI/transactions
CHESS_MINT=               # Optional server-side mirror; defaults to VITE_CHESS_MINT

# Solana RPC (server-side; used for escrow/balance checks)
SOLANA_RPC_URL=           # e.g. https://mainnet.helius-rpc.com/?api-key=...
HELIUS_API_KEY=

# Dev-only: allow an ephemeral "guest" wallet so the play area is reachable
# without a browser extension. MUST be unset/false in production.
VITE_ALLOW_GUEST_WALLET=false
